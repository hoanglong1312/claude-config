{
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/hooks/caveman-statusline.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/session-resume.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/project-check.js"
          }
        ]
      }
    ]
  }
}
